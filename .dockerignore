# ── Runtimes (reinstalled in image) ──────────────────────────────────────────
node_modules/
web-wrapper/frontend/node_modules/
web-wrapper/backend/.venv/

# ── Build artifacts ───────────────────────────────────────────────────────────
web-wrapper/frontend/dist/
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

# ── Git ───────────────────────────────────────────────────────────────────────
.git/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
vite-*.err.log
vite-*.out.log

# ── Personal data (gitignored — don't bake into image) ───────────────────────
# These are created via onboarding after first deploy, then persisted via volume.
cv.md
config/profile.yml
portals.yml
modes/_profile.md
data/applications.md
data/pipeline.md
data/scan-history.tsv
reports/*.md
output/
jds/
writing-samples/
interview-prep/
.env
.update-dismissed
.update-lock
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/**/*.tsv
